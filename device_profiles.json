package com.Andrew.smarthomeble.data.ble

import android.util.Log
import com.Andrew.smarthomeble.data.model.CommandConfig

object CommandBuilder {

    private const val TAG = "CommandBuilder"

    fun build(
        config: CommandConfig,
        value: Int? = null,
        colorValues: Triple<Int, Int, Int>? = null
    ): ByteArray {
        val bytes = mutableListOf<Byte>()

        for (item in config.bytes) {
            when (item) {
                is Double -> bytes.add(item.toInt().toByte())
                is Int -> bytes.add(item.toByte())
                is String -> {
                    when (item) {
                        "VALUE" -> bytes.add((value ?: 0).toByte())
                        "R" -> bytes.add((colorValues?.first ?: 255).toByte())
                        "G" -> bytes.add((colorValues?.second ?: 255).toByte())
                        "B" -> bytes.add((colorValues?.third ?: 255).toByte())
                        else -> {
                            try {
                                bytes.add(item.toInt().toByte())
                            } catch (e: NumberFormatException) {
                                Log.w(TAG, "Неизвестный параметр: '$item'")
                                bytes.add(0)
                            }
                        }
                    }
                }
            }
        }

        // ВЫКЛЮЧЕНО: контрольная сумма для ELK-BLEDOM
        // Последний байт уже задан в JSON как фиксированный 0xEF (239)

        val result = bytes.toByteArray()
        Log.d(TAG, "Команда «${config.name}» → ${result.joinToString(" ") { "%02X".format(it) }}")
        return result
    }

    fun buildByName(
        commands: Map<String, CommandConfig>?,
        commandName: String,
        value: Int? = null
    ): ByteArray? {
        val config = commands?.get(commandName) ?: return null
        return build(config, value)
    }

    fun buildColorCommand(
        commands: Map<String, CommandConfig>?,
        commandName: String,
        red: Int,
        green: Int,
        blue: Int
    ): ByteArray? {
        val config = commands?.get(commandName) ?: return null
        return build(config, colorValues = Triple(red, green, blue))
    }
}
